# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: Public frontend URL (OAuth redirects, emails, CORS allowlist).
APP_URL="http://localhost:3000"
# Public Railway API custom domain (used to distinguish platform traffic from customer hostnames).
API_URL="http://localhost:3000"

# Extra browser origins allowed to call the API (comma-separated).
# Example production: CORS_ORIGINS="https://acnlink.mindflo.today,https://www.acnlink.mindflo.today"
CORS_ORIGINS=""

# Auth
AUTH_SECRET="replace-with-a-long-random-secret-at-least-32-chars"
# Expose OTP/verification tokens in API responses (dev only). Set false in production.
AUTH_EXPOSE_TOKENS="true"
# Seed demo user acnlink@gmail.com / acnlink1234 (dev only).
AUTH_SEED_DEMO="true"
# Allow email-prompt OAuth when Google/GitHub env vars are missing (dev only).
AUTH_ALLOW_DEV_OAUTH="true"

# Supabase (Railway backend). Run supabase/schema.sql once in SQL Editor.
# Then: npm run migrate:supabase  (uploads data-store.json → all tables)
SUPABASE_URL="https://YOUR_PROJECT.supabase.co"
SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""

# Production custom domains — Cloudflare for SaaS
# 1) Configure a fallback origin in Cloudflare for SaaS pointing to Railway.
# 2) Create domains.acnlink.mindflo.today as the customer CNAME target.
# 3) Use a scoped token with SSL and Certificates / Custom Hostnames edit access.
CUSTOM_DOMAIN_CNAME_TARGET="domains.acnlink.mindflo.today"
CLOUDFLARE_ZONE_ID=""
CLOUDFLARE_API_TOKEN=""
CLOUDFLARE_SSL_VALIDATION_METHOD="http"

# Optional SMTP — when set, verification & reset emails are delivered for real.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="ACN Link <noreply@acn.link>"

# --- Vercel (frontend build) ---
# Railway public URL (no trailing slash). Required on Vercel so UI calls the API.
# VITE_API_URL="https://acn-link-production.up.railway.app"
# true  = always use client preview login
# false = never fall back to preview (real API only)
# unset = auto: preview when /api/auth is unreachable
# VITE_AUTH_PREVIEW=false

# Optional real OAuth providers
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""
